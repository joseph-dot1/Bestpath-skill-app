# --- Supabase (required) ------------------------------------------------------
# Free tier. Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, used for AI-generated writes that bypass RLS.
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI provider (one required) -----------------------------------------------
# FREE (recommended to start): get a key at https://aistudio.google.com — no
# card needed. Uses gemini-2.5-flash + gemini-2.5-flash-lite by default.
GEMINI_API_KEY=
# PAID (highest quality): switch any time by setting this + LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
# Optional: force a provider (gemini | anthropic). Auto-detects if unset.
# LLM_PROVIDER=gemini
# Optional model overrides:
# GEMINI_REASONING_MODEL=gemini-2.5-flash
# GEMINI_FAST_MODEL=gemini-2.5-flash-lite

# --- YouTube curation (required) ------------------------------------------------
# Free 10,000 units/day: console.cloud.google.com → enable "YouTube Data API v3"
# → Credentials → API key.
YOUTUBE_API_KEY=
# Optional: override the daily unit budget the app enforces on itself.
# YOUTUBE_DAILY_UNIT_BUDGET=10000

# --- Email & retention (optional, free tier available) --------------------------
# resend.com free tier: 3,000 emails/month.
RESEND_API_KEY=
# Verified sender, e.g. "Bestpath <hello@yourdomain.com>"
EMAIL_FROM=
# Absolute URL of the deployed app (used in email links)
NEXT_PUBLIC_APP_URL=
# Shared secret protecting the cron endpoints (Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=
