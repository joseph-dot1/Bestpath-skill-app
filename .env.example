# --- Supabase (required from Milestone 0) -----------------------------------
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, used for AI-generated writes that bypass RLS.
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI & curation (required from Milestone 2/3) -----------------------------
ANTHROPIC_API_KEY=
YOUTUBE_API_KEY=
# Optional: override the default 10,000-unit daily YouTube quota budget.
# YOUTUBE_DAILY_UNIT_BUDGET=10000

# --- Email & retention (required from Milestone 5) ---------------------------
RESEND_API_KEY=
# Verified sender, e.g. "Bestpath <hello@yourdomain.com>"
EMAIL_FROM=
# Absolute URL of the deployed app (used in email links)
NEXT_PUBLIC_APP_URL=
# Shared secret protecting /api/cron/nudges (Vercel sets Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=
